# Firebase Functions runtime params.
TRIMIT_APP_URL=https://trimitapp.web.app
TRIMIT_UNSUBSCRIBE_BASE_URL=https://southamerica-east1-trimitapp.cloudfunctions.net/unsubscribePaymentReminders

# SMTP used by Nodemailer.
# Do not put TRIMIT_SMTP_PASS here. Set it as a Firebase secret:
# firebase functions:secrets:set TRIMIT_SMTP_PASS
TRIMIT_SMTP_HOST=smtp.gmail.com
TRIMIT_SMTP_PORT=587
TRIMIT_SMTP_SECURE=false
TRIMIT_SMTP_USER=trimitcol@gmail.com
TRIMIT_EMAIL_FROM=Trimit <trimitcol@gmail.com>
TRIMIT_EMAIL_REPLY_TO=trimitcol@gmail.com
